# =============================================================================
# .gitignore
# =============================================================================

# ── Dados (demasiado grandes para o repositório) ──────────────────────────────
data/
*.csv

# ── Outputs gerados localmente ────────────────────────────────────────────────
outputs/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Ambientes virtuais ────────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Modelos guardados ─────────────────────────────────────────────────────────
*.h5
*.keras
saved_models/

# ── Sistema operativo ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
